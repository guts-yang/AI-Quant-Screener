# iFinD
IFIND_BASE_URL=https://quantapi.51ifind.com/api/v1
IFIND_REFRESH_TOKEN=
IFIND_ACCESS_TOKEN=
IFIND_ACCESS_TOKEN_EXPIRE_SECONDS=3600
IFIND_HTTP_TIMEOUT_SECONDS=20
FINANCIAL_CACHE_TTL_HOURS=24

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_HTTP_TIMEOUT_SECONDS=60

# Tushare: 用于拉取沪深300/中证500/中证1000等指数成分
ENABLE_TUSHARE=1
TUSHARE_TOKEN=
TUSHARE_BASE_URL=https://api.waditu.com
TUSHARE_HTTP_TIMEOUT_SECONDS=20

# TickFlow (Optional)
ENABLE_TICKFLOW=0
TICKFLOW_API_KEY=
TICKFLOW_BASE_URL=https://api.tickflow.com/v1
TICKFLOW_HTTP_TIMEOUT_SECONDS=20

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8006
